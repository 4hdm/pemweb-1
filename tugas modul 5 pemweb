<?php
// Inisialisasi variabel untuk menampung pesan kesalahan atau data valid
$error_pesan = "";
$sukses = false;
$nama = $email = $pesan = "";

// 1 & 2. Memproses formnya sendiri (self-processing) dengan metode POST
if ($_SERVER["REQUEST_METHOD"] == "POST" && isset($_POST['kirim'])) {
    
    // Ambil data dan bersihkan spasi di awal/akhir
    $nama_input = trim($_POST['nama_lengkap']);
    $email_input = trim($_POST['alamat_email']);
    $pesan_input = trim($_POST['pesan_komentar']);

    // 3. Validasi Sisi Server: Pastikan tidak ada kolom yang kosong
    if (empty($nama_input) || empty($email_input) || empty($pesan_input)) {
        $error_pesan = "Semua kolom input wajib diisi! Tidak boleh ada yang kosong.";
    } else {
        // Jika lolos validasi, bersihkan dengan htmlspecialchars untuk mencegah XSS
        $nama = htmlspecialchars($nama_input);
        $email = htmlspecialchars($email_input);
        $pesan = htmlspecialchars($pesan_input);
        $sukses = true;
    }
}
?>

